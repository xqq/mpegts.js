{
  "name": "mpegts.js",
  "version": "1.8.0",
  "description": "HTML5 MPEG2-TS Stream Player",
  "main": "./dist/mpegts.js",
  "types": "./d.ts/mpegts.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/xqq/mpegts.js"
  },
  "keywords": [
    "html5",
    "mpegts",
    "m2ts",
    "mse",
    "arib",
    "dvb"
  ],
  "scripts": {
    "build": "webpack --mode=production --progress",
    "build:debug": "webpack --mode=development --progress",
    "lint": "eslint src webpack.config.js",
    "tsc": "tsc -p tsconfig.json --noEmit --skipLibCheck && tsc -p types/tsconfig.json --skipLibCheck",
    "check": "pnpm lint && pnpm tsc",
    "watch": "webpack --mode=development --progress --watch",
    "serve": "webpack serve --mode=development --progress",
    "prepare": "husky"
  },
  "dependencies": {
    "es6-promise": "^4.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express-serve-static-core": "4.17.37",
    "@types/node": "^18.19.130",
    "@webpack-cli/serve": "^1.7.0",
    "browser-sync": "^2.26.10",
    "eslint": "^9.39.4",
    "exports-loader": "^0.7.0",
    "file-loader": "^3.0.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "loader-utils": ">=1.4.1",
    "minimist": ">=1.2.6",
    "prettier": "^3.8.3",
    "socket.io-parser": ">=3.3.3",
    "source-map-loader": "^0.2.4",
    "ssri": ">=8.0.1",
    "terser-webpack-plugin": "^1.2.3",
    "ts-loader": "^8.4.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.2",
    "webpack": "^4.47.0",
    "webpack-cli": "^4.4.0",
    "webpack-dev-server": "^4.9.3",
    "ws": ">=7.4.6",
    "xmlhttprequest-ssl": ">=1.6.2"
  },
  "author": "zheng qian <xqq@xqq.im>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
